<style>
:root {
    --pos-black:       #050505;
    --pos-black-2:     #1a1a1a;
    --pos-gold:        #d4a63d;
    --pos-gold-hover:  #c49430;
    --pos-gold-light:  #f7e7bf;
    --pos-gold-bg:     #fdf8ee;
    --pos-bg:          #f7f4ed;
    --pos-surface:     #ffffff;
    --pos-border:      #e5e7eb;
    --pos-text:        #111827;
    --pos-muted:       #6b7280;
    --pos-success:     #16a34a;
    --pos-danger:      #dc2626;
    --pos-warning:     #d97706;
}
.pos-wrapper { background: var(--pos-bg); min-height: 100vh; overflow: hidden; }
.pos-layout { display: grid; grid-template-columns: 360px 1fr; height: 100vh; }
.pos-cart-panel { background: var(--pos-surface); display: flex; flex-direction: column; height: 100vh; border-right: 1px solid var(--pos-border); }
.pos-cart-header { background: var(--pos-black); color: #ffffff; padding: 16px; flex-shrink: 0; }
.pos-gold { color: var(--pos-gold) !important; }
.pos-muted { color: var(--pos-muted); }
.pos-cart-body { flex: 1; overflow-y: auto; padding: 12px; scrollbar-width: thin; scrollbar-color: var(--pos-gold) var(--pos-bg); }
.pos-cart-body::-webkit-scrollbar { width: 5px; }
.pos-cart-body::-webkit-scrollbar-thumb { background: var(--pos-gold); border-radius: 4px; }
.pos-cart-item { background: var(--pos-surface); border: 1px solid var(--pos-border); border-radius: 8px; padding: 10px 12px; margin-bottom: 8px; transition: border-color .2s; }
.pos-cart-item:hover { border-color: var(--pos-gold); }
.pos-item-name { font-size: 0.83rem; font-weight: 600; color: var(--pos-text); }
.pos-item-code { font-size: 0.72rem; color: var(--pos-muted); }
.pos-item-total { font-size: 0.85rem; font-weight: 700; color: var(--pos-gold); }
.pos-item-unit  { font-size: 0.72rem; color: var(--pos-muted); }
.pos-item-discount { font-size: 0.72rem; color: var(--pos-danger); margin-top: 4px; }
.pos-qty-control { display: flex; align-items: center; gap: 2px; }
.pos-qty-btn { background: none; border: 1px solid var(--pos-border); border-radius: 4px; width: 26px; height: 26px; display: flex; align-items: center; justify-content: center; cursor: pointer; font-size: 0.75rem; color: var(--pos-text); transition: all .15s; }
.pos-qty-btn:hover { background: var(--pos-gold); border-color: var(--pos-gold); color: #fff; }
.pos-qty-input { width: 44px; height: 26px; border: 1px solid var(--pos-border); border-radius: 4px; text-align: center; font-size: 0.8rem; font-weight: 600; outline: none; padding: 0; color: var(--pos-text); }
.pos-qty-input:focus { border-color: var(--pos-gold); }
.pos-btn-remove { background: none; border: none; color: var(--pos-muted); padding: 2px 5px; font-size: 0.7rem; border-radius: 4px; transition: all .15s; line-height: 1; }
.pos-btn-remove:hover { background: #fef2f2; color: var(--pos-danger); }
.pos-empty-cart { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40px 20px; color: var(--pos-muted); text-align: center; }
.pos-empty-cart i { font-size: 3rem; margin-bottom: 8px; opacity: .4; }
.pos-empty-cart p { font-size: 0.85rem; margin: 0; }
.pos-empty-cart small { font-size: 0.75rem; }
.pos-cart-footer { border-top: 1px solid var(--pos-border); padding: 14px; background: var(--pos-surface); flex-shrink: 0; }
.pos-totals { margin-bottom: 12px; }
.pos-total-row { display: flex; justify-content: space-between; align-items: center; font-size: 0.82rem; color: var(--pos-text); padding: 3px 0; }
.pos-discount-row { color: var(--pos-danger); }
.pos-extra-discount-row { margin: 4px 0; }
.pos-grand-total-row { display: flex; justify-content: space-between; align-items: center; font-size: 1rem; font-weight: 700; color: var(--pos-text); border-top: 2px solid var(--pos-border); margin-top: 6px; padding-top: 8px; }
.pos-grand-total-row span:last-child { color: var(--pos-gold); }
.pos-discount-input { width: 70px; height: 28px; border: 1px solid var(--pos-border); border-radius: 4px 0 0 4px; padding: 0 6px; font-size: 0.8rem; outline: none; }
.pos-discount-input:focus { border-color: var(--pos-gold); }
.pos-discount-toggle { background: var(--pos-black); color: var(--pos-gold); border: 1px solid var(--pos-black); border-radius: 0 4px 4px 0; height: 28px; padding: 0 8px; font-size: 0.75rem; font-weight: 700; cursor: pointer; transition: all .15s; }
.pos-discount-toggle:hover { background: var(--pos-gold); color: var(--pos-black); border-color: var(--pos-gold); }
.pos-payment-methods { margin-bottom: 10px; }
.pos-pm-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 4px; }
.pos-pm-radio { display: none; }
.pos-pm-label { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 3px; padding: 7px 4px; border: 1px solid var(--pos-border); border-radius: 6px; font-size: 0.7rem; font-weight: 500; color: var(--pos-muted); cursor: pointer; transition: all .15s; background: var(--pos-surface); }
.pos-pm-label i { font-size: 1rem; }
.pos-pm-label:hover { border-color: var(--pos-gold); color: var(--pos-text); }
.pos-pm-radio:checked + .pos-pm-label { background: var(--pos-black); border-color: var(--pos-black); color: var(--pos-gold); }
.pos-payment-inputs { margin-bottom: 10px; }
.pos-input-group { margin-bottom: 8px; }
.pos-input-prefix-sm { background: var(--pos-bg); border-color: var(--pos-border); font-size: 0.78rem; padding: 4px 8px; border-radius: 0 !important; }
.pos-due-notice { background: var(--pos-gold-bg); border: 1px solid var(--pos-gold-light); border-radius: 6px; padding: 8px 12px; font-size: 0.78rem; color: var(--pos-warning); }
.pos-due-amount { display: flex; justify-content: space-between; background: #fef2f2; border: 1px solid #fecaca; border-radius: 6px; padding: 7px 10px; font-size: 0.8rem; font-weight: 600; color: var(--pos-danger); margin-bottom: 10px; }
.pos-btn-complete { background: var(--pos-black); color: var(--pos-gold); border: 2px solid var(--pos-black); font-weight: 700; font-size: 0.9rem; border-radius: 8px !important; padding: 12px; transition: all .2s; }
.pos-btn-complete:hover:not(:disabled) { background: var(--pos-gold); color: var(--pos-black); border-color: var(--pos-gold); }
.pos-btn-complete:disabled { opacity: .5; cursor: not-allowed; }
.pos-btn-clear { background: none; color: var(--pos-danger); border: 1px solid #fecaca; font-size: 0.82rem; border-radius: 6px !important; padding: 8px; transition: all .15s; }
.pos-btn-clear:hover { background: #fef2f2; }
.pos-btn-ghost-sm { background: rgba(255,255,255,0.1); color: var(--pos-gold); border: 1px solid rgba(255,255,255,0.2); font-size: 0.75rem; padding: 4px 10px; border-radius: 5px !important; transition: all .15s; }
.pos-btn-ghost-sm:hover { background: var(--pos-gold); color: var(--pos-black); border-color: var(--pos-gold); }
.pos-btn-icon { background: rgba(255,255,255,0.1); color: var(--pos-gold); border: 1px solid rgba(255,255,255,0.2); padding: 5px 9px; border-radius: 5px !important; transition: all .15s; }
.pos-btn-icon:hover { background: var(--pos-gold); color: var(--pos-black); }
.pos-select { background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.25); color: #fff; font-size: 0.82rem; padding: 5px 8px; border-radius: 5px !important; }
.pos-select:focus { border-color: var(--pos-gold); box-shadow: none; background: rgba(255,255,255,0.2); color: #fff; }
.pos-select option { background: var(--pos-black); color: #fff; }
.pos-products-panel { display: flex; flex-direction: column; height: 100vh; background: var(--pos-bg); overflow: hidden; }
.pos-top-bar { background: var(--pos-surface); border-bottom: 1px solid var(--pos-border); padding: 12px 20px; display: flex; justify-content: space-between; align-items: center; flex-shrink: 0; }
.pos-shop-name { font-size: 1rem; color: var(--pos-black); letter-spacing: 0.03em; }
.pos-clock { font-size: 1rem; color: var(--pos-gold); }
.pos-search-wrap { background: var(--pos-surface); border-bottom: 1px solid var(--pos-border); padding: 12px 16px; position: relative; flex-shrink: 0; }
.pos-search-box { display: flex; align-items: center; border: 2px solid var(--pos-border); border-radius: 8px; background: var(--pos-bg); padding: 0 12px; transition: border-color .2s; }
.pos-search-box:focus-within { border-color: var(--pos-gold); background: var(--pos-surface); }
.pos-search-icon { color: var(--pos-muted); font-size: 0.9rem; flex-shrink: 0; }
.pos-search-input { flex: 1; border: none; background: none; padding: 10px 8px; font-size: 0.85rem; outline: none; color: var(--pos-text); }
.pos-search-input::placeholder { color: var(--pos-muted); }
.pos-search-clear { background: none; border: none; color: var(--pos-muted); padding: 4px; cursor: pointer; font-size: 0.75rem; }
.pos-search-clear:hover { color: var(--pos-danger); }
.pos-search-dropdown { position: absolute; top: calc(100% - 2px); left: 16px; right: 16px; background: var(--pos-surface); border: 2px solid var(--pos-gold); border-radius: 0 0 8px 8px; box-shadow: 0 8px 24px rgba(0,0,0,0.12); z-index: 1000; max-height: 280px; overflow-y: auto; }
.pos-search-result { display: flex; justify-content: space-between; align-items: center; padding: 10px 14px; cursor: pointer; border-bottom: 1px solid var(--pos-border); font-size: 0.83rem; transition: background .1s; }
.pos-search-result:last-child { border-bottom: none; }
.pos-search-result:hover { background: var(--pos-gold-bg); }
.pos-search-price { font-weight: 700; color: var(--pos-gold); }
.pos-categories { background: var(--pos-surface); border-bottom: 1px solid var(--pos-border); padding: 10px 16px; display: flex; gap: 6px; flex-wrap: wrap; flex-shrink: 0; }
.pos-cat-btn { background: none; border: 1px solid var(--pos-border); border-radius: 20px; padding: 4px 14px; font-size: 0.78rem; font-weight: 500; color: var(--pos-muted); cursor: pointer; transition: all .15s; white-space: nowrap; }
.pos-cat-btn:hover { border-color: var(--pos-gold); color: var(--pos-text); }
.pos-cat-btn.active { background: var(--pos-black); border-color: var(--pos-black); color: var(--pos-gold); }
.pos-products-scroll { flex: 1; overflow-y: auto; padding: 14px; scrollbar-width: thin; scrollbar-color: var(--pos-gold) var(--pos-bg); }
.pos-products-scroll::-webkit-scrollbar { width: 5px; }
.pos-products-scroll::-webkit-scrollbar-thumb { background: var(--pos-gold); border-radius: 4px; }
.pos-products-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(145px, 1fr)); gap: 10px; }
.pos-product-card { background: var(--pos-surface); border: 1px solid var(--pos-border); border-radius: 10px; cursor: pointer; overflow: hidden; transition: all .2s; }
.pos-product-card:hover { border-color: var(--pos-gold); box-shadow: 0 4px 16px rgba(212,166,61,0.18); transform: translateY(-2px); }
.pos-product-card:active { transform: scale(0.97); }
.pos-product-img { position: relative; height: 95px; background: var(--pos-bg); overflow: hidden; }
.pos-product-img img { width: 100%; height: 100%; object-fit: cover; }
.pos-product-noimg { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: var(--pos-muted); font-size: 2rem; opacity: .4; }
.pos-stock-badge { position: absolute; top: 6px; right: 6px; font-size: 0.65rem; font-weight: 700; padding: 2px 6px; border-radius: 10px; }
.pos-stock-badge.in-stock { background: #dcfce7; color: #15803d; }
.pos-stock-badge.out-stock { background: #fee2e2; color: #dc2626; }
.pos-product-info { padding: 8px 10px; }
.pos-product-name { font-size: 0.78rem; font-weight: 600; color: var(--pos-text); height: 30px; overflow: hidden; line-height: 1.35; margin-bottom: 2px; }
.pos-product-code { font-size: 0.7rem; color: var(--pos-muted); margin-bottom: 4px; }
.pos-product-price { font-size: 0.88rem; font-weight: 700; color: var(--pos-gold); }
.pos-no-products { grid-column: 1 / -1; padding: 48px 0; text-align: center; color: var(--pos-muted); }
.pos-no-products i { font-size: 3rem; opacity: .3; display: block; margin-bottom: 8px; }
.pos-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.75); display: flex; align-items: center; justify-content: center; z-index: 1500; padding: 20px; }
.pos-modal-card { background: var(--pos-surface); border-radius: 12px; overflow: hidden; box-shadow: 0 24px 60px rgba(0,0,0,0.3); width: 100%; }
.pos-modal-header { background: var(--pos-black); color: #ffffff; padding: 16px 20px; display: flex; justify-content: space-between; align-items: center; }
.pos-modal-warning { background: #78350f; }
.pos-icon-badge { width: 36px; height: 36px; border-radius: 8px; background: rgba(212,166,61,0.2); border: 1px solid var(--pos-gold); display: flex; align-items: center; justify-content: center; color: var(--pos-gold); font-size: 1rem; flex-shrink: 0; }
.pos-icon-badge.warning { background: rgba(255,200,0,0.2); border-color: #fbbf24; color: #fbbf24; }
.pos-modal-body { padding: 20px; max-height: 65vh; overflow-y: auto; }
.pos-modal-footer { padding: 14px 20px; border-top: 1px solid var(--pos-border); display: flex; justify-content: flex-end; gap: 8px; background: var(--pos-bg); }
.pos-btn-close { background: rgba(255,255,255,0.1); color: #fff; border: none; border-radius: 6px !important; padding: 4px 8px; font-size: 0.75rem; transition: all .15s; }
.pos-btn-close:hover { background: rgba(255,255,255,0.25); color: #fff; }
.pos-btn-primary { background: var(--pos-black); color: var(--pos-gold); border: 2px solid var(--pos-black); border-radius: 7px !important; font-weight: 600; font-size: 0.83rem; padding: 7px 16px; transition: all .15s; }
.pos-btn-primary:hover { background: var(--pos-gold); color: var(--pos-black); border-color: var(--pos-gold); }
.pos-btn-secondary { background: var(--pos-bg); color: var(--pos-text); border: 1px solid var(--pos-border); border-radius: 7px !important; font-size: 0.83rem; padding: 7px 16px; transition: all .15s; }
.pos-btn-secondary:hover { border-color: var(--pos-gold); }
.pos-btn-outline { background: none; color: var(--pos-text); border: 1px solid var(--pos-border); border-radius: 7px !important; font-size: 0.83rem; padding: 7px 16px; transition: all .15s; }
.pos-btn-outline:hover { border-color: var(--pos-gold); }
.pos-label { font-size: 0.8rem; font-weight: 600; color: var(--pos-text); margin-bottom: 4px; display: block; }
.pos-input { font-size: 0.82rem !important; border: 1px solid var(--pos-border) !important; border-radius: 6px !important; color: var(--pos-text) !important; padding: 7px 10px !important; background: var(--pos-surface) !important; width: 100%; }
.pos-input:focus { border-color: var(--pos-gold) !important; box-shadow: 0 0 0 3px rgba(212,166,61,0.15) !important; }
.pos-input-lg { font-size: 1.5rem !important; border: 2px solid var(--pos-border) !important; border-radius: 0 6px 6px 0 !important; font-weight: 700 !important; text-align: center; padding: 12px !important; }
.pos-input-lg:focus { border-color: var(--pos-gold) !important; box-shadow: 0 0 0 3px rgba(212,166,61,0.15) !important; }
.pos-input-prefix { background: var(--pos-black); color: var(--pos-gold); font-weight: 700; border: 2px solid var(--pos-black); border-radius: 6px 0 0 6px !important; font-size: 0.9rem; padding: 12px 14px; }
.pos-cash-icon-wrap { width: 64px; height: 64px; border-radius: 16px; background: var(--pos-gold-bg); border: 2px solid var(--pos-gold-light); display: flex; align-items: center; justify-content: center; font-size: 2rem; color: var(--pos-gold); }
.pos-info-box { background: var(--pos-gold-bg); border: 1px solid var(--pos-gold-light); border-radius: 8px; padding: 10px 14px; font-size: 0.8rem; color: #92400e; }
.pos-field-error { font-size: 0.75rem; color: var(--pos-danger); margin-top: 4px; }
.pos-summary-table { border: 1px solid var(--pos-border); border-radius: 8px; overflow: hidden; }
.pos-summary-row { display: flex; justify-content: space-between; padding: 9px 14px; font-size: 0.83rem; border-bottom: 1px solid var(--pos-border); }
.pos-summary-row:last-child { border-bottom: none; }
.pos-summary-due { background: #fef2f2; color: var(--pos-danger); font-weight: 600; }
.pos-success-text { color: var(--pos-success); }
.pos-register-table { border: 1px solid var(--pos-border); border-radius: 8px; overflow: hidden; }
.pos-reg-row { display: flex; justify-content: space-between; padding: 7px 14px; font-size: 0.8rem; border-bottom: 1px solid var(--pos-border); color: var(--pos-text); }
.pos-reg-row:last-child { border-bottom: none; }
.pos-reg-row.highlight { background: var(--pos-gold-bg); }
.pos-reg-row.sub { background: #fafafa; color: var(--pos-muted); }
.pos-reg-row.total { background: var(--pos-black); color: var(--pos-gold); font-size: 0.88rem; }
.pos-alert { border-radius: 8px; padding: 10px 14px; font-size: 0.82rem; margin-top: 10px; }
.pos-alert-warning { background: #fffbeb; border: 1px solid #fcd34d; color: #92400e; }
.pos-alert-danger  { background: #fef2f2; border: 1px solid #fca5a5; color: #7f1d1d; }
.pos-invoice-table { font-size: 0.82rem !important; }
.pos-invoice-table th { background: var(--pos-black); color: var(--pos-gold); font-weight: 600; padding: 8px 10px; font-size: 0.75rem; }
.pos-invoice-table td { padding: 7px 10px; }
.pos-invoice-label { font-size: 0.72rem; color: var(--pos-muted); text-transform: uppercase; letter-spacing: .05em; margin-bottom: 2px; }
.pos-sig-line { border-bottom: 2px solid var(--pos-border); margin-bottom: 6px; height: 24px; }
.pos-invoice-footer-note { background: var(--pos-bg); border: 1px solid var(--pos-border); border-radius: 8px; padding: 12px 16px; font-size: 0.8rem; text-align: center; }
.print-only-header, .print-header, .print-footer, .register-print-footer { display: none; }
@media print {
    body * { visibility: hidden; }
    #saleReceiptPrintContent, #saleReceiptPrintContent * { visibility: visible !important; }
    #saleReceiptPrintContent { position: absolute !important; inset: 0 !important; padding: 15mm !important; background: white !important; }
    .modal-header, .modal-footer, .btn, .badge, .screen-only-header, .no-print { display: none !important; }
    .print-only-header { display: block !important; visibility: visible !important; }
    .invoice-table { width: 100% !important; border-collapse: collapse !important; font-size: 11px !important; }
    .invoice-table th { background: #f5f5f5 !important; border: 1px solid #000 !important; padding: 6px !important; }
    .invoice-table td { border: 1px solid #000 !important; padding: 5px 8px !important; }
    .totals-row td { border-top: 2px solid #000 !important; font-weight: bold !important; }
    .grand-total td { border-top: 3px double #000 !important; font-size: 13px !important; }
    @page { size: A4 portrait; margin: 15mm; }
}
@media screen { .print-only-header { display: none !important; } }
</style>
@endpush

@push(''scripts'')
<script>
document.addEventListener(''livewire:initialized'', () => {
    Livewire.on(''showModal'', (event) => {
        const modalId = Array.isArray(event) ? event[0] : event;
        setTimeout(() => {
            const el = document.getElementById(modalId);
            if (el) {
                const existing = bootstrap.Modal.getInstance(el);
                if (existing) existing.dispose();
                new bootstrap.Modal(el, { backdrop: ''static'', keyboard: false }).show();
            }
        }, 200);
    });
});
</script>
@endpush
